# AURICX Environment Configuration
# Copy to .env.local and fill in your values

# ─── Price Provider ──────────────────────────────────────────
# "mock" = random walk simulation (default, no API needed)
# "skinport" = live prices from Skinport API
NEXT_PUBLIC_PRICE_PROVIDER=mock

# ─── Skinport API (only needed if PRICE_PROVIDER=skinport) ──
SKINPORT_APP_ID=
SKINPORT_APP_SECRET=

# ─── Demo Mode ───────────────────────────────────────────────
NEXT_PUBLIC_DEMO=true
